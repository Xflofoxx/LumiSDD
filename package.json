{
  "name": "@xflofoxx/lumisdk",
  "version": "1.0.0",
  "description": "Lightweight Spec Driven Development framework for modern software engineering",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs"
    },
    "./validators": {
      "types": "./dist/validators/index.d.ts",
      "import": "./dist/validators/index.mjs"
    },
    "./generators": {
      "types": "./dist/generators/index.d.ts",
      "import": "./dist/generators/index.mjs"
    },
    "./trackers": {
      "types": "./dist/trackers/index.d.ts",
      "import": "./dist/trackers/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "release": "changeset version && changeset publish"
  },
  "keywords": [
    "spec",
    "sdd",
    "spec-driven-development",
    "specification",
    "validation",
    "code-generation",
    "openapi",
    "json-schema",
    "requirements",
    "engineering"
  ],
  "author": "Xflofoxx",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xflofoxx/LumiSDD.git"
  },
  "bugs": {
    "url": "https://github.com/Xflofoxx/LumiSDD/issues"
  },
  "homepage": "https://xflofoxx.github.io/LumiSDD",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "typescript": "^5.7.3",
    "tsup": "^8.4.0",
    "vitest": "^3.0.8",
    "eslint": "^9.21.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npmjs.org/"
  }
}
